// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  password    String?
  firstName   String
  lastName    String
  phone       String?
  image       String?
  provider    String?   // "google" | "credentials"
  bio         String?
  location    String?
  dateOfBirth DateTime?
  age         Int?
  occupation  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  assets      Asset[]

  @@map("users")
}

model Asset {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type        AssetType
  symbol      String    // BTCUSDT, AAPL, GC=F, USD/VND
  name        String    // Bitcoin, Apple Inc, Gold, US Dollar
  quantity    Float
  avgBuyPrice Float     // Average purchase price
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([userId])
  @@index([symbol])
  @@map("assets")
}

model MarketPrice {
  id            String    @id @default(cuid())
  symbol        String
  type          AssetType
  price         Float
  change24h     Float?
  changePercent Float?
  volume24h     Float?
  marketCap     Float?
  timestamp     DateTime  @default(now())
  
  @@index([symbol, timestamp])
  @@map("market_prices")
}

enum AssetType {
  CRYPTO
  FOREX
  STOCK_US
  STOCK_VN
  GOLD
  SILVER
  CASH
  SAVINGS
  REAL_ESTATE
  ALTERNATIVE
  COLLECTIBLES
}
